NEO4J_PASSWORD=change-me-before-starting
NEO4J_DATABASE=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL_SIZE=512M
NEO4J_HEAP_MAX_SIZE=1G
NEO4J_PAGECACHE_SIZE=512M

GRAPHITI_API_PORT=8765
GRAPHITI_API_URL=http://localhost:8765
LOG_LEVEL=INFO
GRAPHITI_STARTUP_TIMEOUT_SECONDS=30
NEO4J_HEALTH_TIMEOUT_SECONDS=5
REQUEST_TIMEOUT_SECONDS=15
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2
SEMAPHORE_LIMIT=10
GRAPHITI_TELEMETRY_ENABLED=false

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=deepseek/deepseek-v3.2
DEEPSEEK_SMALL_MODEL=deepseek/deepseek-v3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

MARINARA_HOST=http://host.docker.internal:7860
MARINARA_EMBEDDING_PATH=/api/sidecar/v1/embeddings
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSION=4096
EMBEDDING_TIMEOUT_SECONDS=10
ALLOW_DUMMY_EMBEDDINGS=true

GRAPHITI_DEFAULT_CAMPAIGN_ID=marinara-default
GRAPHITI_SEARCH_LIMIT=8
GRAPHITI_MIN_SEARCH_SCORE=0.0
